---
interface Props {
  variant?: 'light' | 'dark';
}
const { variant = 'light' } = Astro.props;
---
<div class={`section-divider sd-${variant}`} aria-hidden="true">
  <span class="sd-line sd-line-l"></span>
  <svg class="sd-sprig" viewBox="0 0 44 22" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" width="44" height="22">
    <path d="M22 21 V3" />
    <path d="M22 17c-4 0-7-2-8-5 3 0 6 1 8 3" />
    <path d="M22 13c4 0 7-2 8-5-3 0-6 1-8 3" />
    <path d="M22 9c-3 0-5-1-6-4 2 0 4 1 6 2" />
    <circle cx="22" cy="3" r="1.2" fill="currentColor" stroke="none" />
  </svg>
  <span class="sd-line sd-line-r"></span>
</div>

<style>
  .section-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    margin: 56px auto 0;
    padding: 0 20px;
    max-width: 560px;
  }
  .sd-light { color: var(--sage-dark); }
  .sd-dark { color: var(--sage); opacity: 0.9; }
  .sd-line {
    flex: 1;
    height: 1px;
    max-width: 200px;
  }
  .sd-light .sd-line-l {
    background: linear-gradient(90deg, transparent 0%, var(--sage) 100%);
  }
  .sd-light .sd-line-r {
    background: linear-gradient(90deg, var(--sage) 0%, transparent 100%);
  }
  .sd-dark .sd-line-l {
    background: linear-gradient(90deg, transparent 0%, rgba(155, 174, 149, 0.6) 100%);
  }
  .sd-dark .sd-line-r {
    background: linear-gradient(90deg, rgba(155, 174, 149, 0.6) 0%, transparent 100%);
  }
  .sd-sprig { flex-shrink: 0; opacity: 0.9; }

  @media (max-width: 640px) {
    .section-divider { margin-top: 40px; gap: 14px; }
    .sd-line { max-width: 120px; }
  }
</style>
