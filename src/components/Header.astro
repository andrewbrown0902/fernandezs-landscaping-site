---
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <img src="/images/logo.jpeg" alt="Fernandez's Landscaping" class="brand-logo" width="60" height="60" />
      <span class="brand-text">
        <span class="brand-name">Fernandez's</span>
        <span class="brand-sub">Landscaping</span>
      </span>
    </a>

    <nav class="nav">
      <a href="#services">Services</a>
      <a href="#gallery">Gallery</a>
      <a href="#areas">Service Area</a>
      <a href="#reviews">Reviews</a>
      <a href="#faq">FAQ</a>
    </nav>

    <div class="header-cta">
      <a href="tel:5743862740" class="phone-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        (574) 386-2740
      </a>
      <a href="#quote" class="btn btn-accent" data-quote-open>Free Quote</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 14px;
    padding-bottom: 14px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }
  .brand-logo {
    width: 60px;
    height: 60px;
    object-fit: cover;
    clip-path: ellipse(46% 49% at 50% 50%);
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand-name {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.4rem;
    color: var(--forest);
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .brand-sub {
    font-family: var(--font-sans);
    font-size: 0.64rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    color: var(--gray);
    margin-top: 6px;
  }
  .nav {
    display: flex;
    gap: 32px;
  }
  .nav a {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.92rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--charcoal);
    position: relative;
  }
  .nav a:hover {
    color: var(--forest);
  }
  .header-cta {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .phone-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--forest);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.02rem;
    letter-spacing: 0.04em;
  }
  .phone-link:hover { color: var(--lime-dark); }

  @media (max-width: 980px) {
    .nav { display: none; }
    .phone-link span { display: none; }
  }
  @media (max-width: 640px) {
    .header-cta .btn { display: none; }
  }
</style>
