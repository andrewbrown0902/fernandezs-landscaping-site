<section class="final-cta">
  <div class="container">
    <div class="final-cta-inner">
      <div class="head-top" style="justify-content: center;">
        <span class="section-num">/ 09</span>
        <span class="section-kicker">Ready When You Are</span>
      </div>
      <h2>A Yard Worth<br/>Coming Home To.</h2>
      <p>Tell us what your property needs and we'll handle the rest. Free estimate. Fair price. Fast turnaround.</p>
      <div class="final-cta-buttons">
        <a href="tel:5743862740" class="btn btn-accent btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call (574) 386-2740
        </a>
        <a href="#quote" class="btn btn-ghost btn-lg" data-quote-open>Request Free Quote</a>
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta {
    background: var(--forest);
    color: var(--cream);
    padding: 100px 0;
    position: relative;
    overflow: hidden;
    --lime: var(--bone);
    --lime-dark: var(--white);
  }
  .final-cta::before {
    content: '';
    position: absolute;
    top: -100px;
    right: -80px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(242, 238, 227, 0.12), transparent 70%);
    pointer-events: none;
  }
  .final-cta-inner {
    position: relative;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }
  .head-top {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 18px;
  }
  .head-top .section-kicker { margin-bottom: 0; color: var(--lime); }
  .head-top .section-num { color: var(--rust); }
  .final-cta h2 {
    color: var(--bone);
    font-size: clamp(2.4rem, 4.5vw, 3.8rem);
    margin-bottom: 22px;
    line-height: 1;
  }
  .final-cta p {
    color: rgba(245, 240, 225, 0.85);
    font-size: 1.12rem;
    margin-bottom: 36px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }
  .final-cta-buttons {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .final-cta { padding: 72px 0; }
    .final-cta-buttons {
      flex-direction: column;
      width: 100%;
      max-width: 340px;
      margin-inline: auto;
      gap: 12px;
    }
    .final-cta-buttons .btn { width: 100%; justify-content: center; }
  }
</style>
