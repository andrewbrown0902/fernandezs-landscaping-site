---
const areas = [
  { name: 'South Bend', primary: true },
  { name: 'Mishawaka' },
  { name: 'Granger' },
  { name: 'Osceola' },
  { name: 'Elkhart' },
  { name: 'Goshen' },
  { name: 'Niles, MI' },
  { name: 'Plymouth' },
  { name: 'La Porte' },
  { name: 'New Carlisle' },
  { name: 'Bremen' },
  { name: 'Buchanan, MI' },
  { name: 'Edwardsburg, MI' },
  { name: 'Nappanee' },
];
---
<section id="areas" class="section">
  <div class="container">
    <div class="areas-grid">
      <div class="areas-copy">
        <div class="head-top">
          <span class="section-num">/ 06</span>
          <span class="section-kicker">Service Area</span>
        </div>
        <h2 class="section-title">South Bend<br/>&amp; Michiana.</h2>
        <p class="section-lede">Based in South Bend. Covering communities across St. Joseph, Elkhart, and surrounding counties — roughly a 30-mile radius. If you're close, we're probably already coming your way.</p>
        <div class="areas-chips">
          {areas.map(a => (
            <span class={`area-chip ${a.primary ? 'primary' : ''}`}>{a.name}</span>
          ))}
        </div>
        <p class="areas-note">Not sure if you're in the area? Give us a call — we travel for the right job.</p>
        <a href="tel:5743862740" class="btn btn-primary" style="margin-top: 20px;">📞 Check availability — (574) 386-2740</a>
      </div>
      <div class="areas-map" aria-hidden="true">
        <div class="map-inner">
          <!-- Stylized static map -->
          <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(42, 74, 46, 0.08)" stroke-width="1"/>
              </pattern>
              <radialGradient id="coverage" cx="50%" cy="50%" r="48%">
                <stop offset="0%" stop-color="#8BC34A" stop-opacity="0.35"/>
                <stop offset="70%" stop-color="#8BC34A" stop-opacity="0.15"/>
                <stop offset="100%" stop-color="#8BC34A" stop-opacity="0"/>
              </radialGradient>
            </defs>
            <rect width="400" height="400" fill="#F5F0E1"/>
            <rect width="400" height="400" fill="url(#grid)"/>
            <!-- State line between IN and MI -->
            <line x1="0" y1="140" x2="400" y2="140" stroke="#2A4A2E" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.4"/>
            <text x="380" y="132" font-family="Inter, sans-serif" font-size="10" fill="#2A4A2E" opacity="0.6" text-anchor="end">MI</text>
            <text x="380" y="156" font-family="Inter, sans-serif" font-size="10" fill="#2A4A2E" opacity="0.6" text-anchor="end">IN</text>
            <!-- Coverage radius -->
            <circle cx="200" cy="200" r="150" fill="url(#coverage)"/>
            <circle cx="200" cy="200" r="150" fill="none" stroke="#8BC34A" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.6"/>
            <!-- Towns -->
            <g font-family="Inter, sans-serif" font-size="11" fill="#2A4A2E">
              <!-- Niles MI -->
              <circle cx="190" cy="115" r="4" fill="#2A4A2E"/>
              <text x="198" y="118">Niles, MI</text>
              <!-- Buchanan MI -->
              <circle cx="135" cy="95" r="3" fill="#2A4A2E" opacity="0.8"/>
              <text x="90" y="85" font-size="10" opacity="0.75">Buchanan</text>
              <!-- Edwardsburg MI -->
              <circle cx="260" cy="100" r="3" fill="#2A4A2E" opacity="0.8"/>
              <text x="268" y="103" font-size="10" opacity="0.75">Edwardsburg</text>
              <!-- South Bend (primary) -->
              <circle cx="200" cy="200" r="10" fill="#8BC34A" stroke="#2A4A2E" stroke-width="2"/>
              <text x="214" y="204" font-weight="700" font-size="13">South Bend</text>
              <!-- Mishawaka -->
              <circle cx="240" cy="210" r="5" fill="#2A4A2E"/>
              <text x="248" y="214" font-weight="600">Mishawaka</text>
              <!-- Granger -->
              <circle cx="230" cy="160" r="4" fill="#2A4A2E"/>
              <text x="238" y="163">Granger</text>
              <!-- Osceola -->
              <circle cx="275" cy="220" r="3.5" fill="#2A4A2E"/>
              <text x="282" y="224">Osceola</text>
              <!-- Elkhart -->
              <circle cx="320" cy="220" r="5" fill="#2A4A2E"/>
              <text x="330" y="224" font-weight="600">Elkhart</text>
              <!-- Goshen -->
              <circle cx="340" cy="290" r="4.5" fill="#2A4A2E"/>
              <text x="350" y="294">Goshen</text>
              <!-- Nappanee -->
              <circle cx="280" cy="330" r="3.5" fill="#2A4A2E" opacity="0.85"/>
              <text x="240" y="350" font-size="10" opacity="0.8">Nappanee</text>
              <!-- Bremen -->
              <circle cx="200" cy="325" r="3.5" fill="#2A4A2E" opacity="0.85"/>
              <text x="208" y="328" font-size="10" opacity="0.8">Bremen</text>
              <!-- Plymouth -->
              <circle cx="160" cy="340" r="4" fill="#2A4A2E" opacity="0.85"/>
              <text x="120" y="355" font-size="10" opacity="0.8">Plymouth</text>
              <!-- New Carlisle -->
              <circle cx="110" cy="215" r="3.5" fill="#2A4A2E" opacity="0.85"/>
              <text x="40" y="218" font-size="10" opacity="0.8">New Carlisle</text>
              <!-- La Porte -->
              <circle cx="60" cy="240" r="4" fill="#2A4A2E" opacity="0.85"/>
              <text x="6" y="234" font-size="10" opacity="0.8">La Porte</text>
            </g>
          </svg>
          <div class="map-caption">~30 mile service radius from South Bend, IN</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .areas-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .areas-copy .section-lede {
    margin-bottom: 32px;
  }
  .areas-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }
  .head-top {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 18px;
  }
  .head-top .section-kicker { margin-bottom: 0; }
  .area-chip {
    display: inline-block;
    padding: 8px 14px;
    background: var(--white);
    color: var(--charcoal);
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1.5px solid var(--charcoal);
  }
  .area-chip.primary {
    background: var(--forest);
    color: var(--bone);
    border-color: var(--forest);
    font-weight: 600;
  }
  .areas-note {
    color: var(--gray);
    font-style: italic;
    font-size: 0.98rem;
  }
  .areas-map {
    position: relative;
  }
  .map-inner {
    background: var(--bone);
    border-radius: 0;
    padding: 24px;
    border: 1.5px solid var(--charcoal);
    box-shadow: 8px 8px 0 var(--forest);
  }
  .map-inner svg {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius);
  }
  .map-caption {
    text-align: center;
    font-size: 0.85rem;
    color: var(--gray);
    margin-top: 14px;
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .areas-grid { grid-template-columns: 1fr; gap: 40px; }
  }
  @media (max-width: 640px) {
    .areas-copy { text-align: center; }
    .head-top { justify-content: center; }
    .areas-chips { justify-content: center; }
    .areas-copy .btn { width: 100%; max-width: 360px; justify-content: center; }
    .map-inner { box-shadow: 5px 5px 0 var(--forest); }
  }
</style>
