---
<div class="top-banner">
  <div class="container tb-inner">
    <div class="tb-info">
      <span class="tb-item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Locally Owned · South Bend &amp; Surrounding Areas
      </span>
      <span class="tb-sep" aria-hidden="true">/</span>
      <span class="tb-item tb-hours">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Mon–Sat 8a–6p
      </span>
      <span class="tb-sep tb-hide-md" aria-hidden="true">/</span>
      <a href="tel:5743862740" class="tb-item tb-phone">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Call or Text (574) 386-2740
      </a>
    </div>
    <div class="tb-social">
      <a href="https://www.facebook.com/people/Fernandezs-landscaping/61574590599260/" target="_blank" rel="noopener" aria-label="Facebook">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z"/></svg>
      </a>
      <a href="https://www.yelp.com/biz/fernandez-landscaping-south-bend" target="_blank" rel="noopener" aria-label="Yelp">
        <img src="/images/yelp.svg" alt="" width="14" height="14" class="tb-yelp-img" aria-hidden="true" />
      </a>
      <a href="https://www.tiktok.com/@mlb0o0o0" target="_blank" rel="noopener" aria-label="TikTok">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.1Z"/></svg>
      </a>
    </div>
  </div>
</div>

<style>
  .top-banner {
    background: var(--forest);
    color: var(--bone);
    border-bottom: 1px solid rgba(242, 238, 227, 0.1);
    position: relative;
    z-index: 101;
  }
  .tb-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 10px;
    padding-bottom: 10px;
    min-height: 38px;
  }
  .tb-info {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(242, 238, 227, 0.78);
  }
  .tb-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(242, 238, 227, 0.85);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .tb-item svg { color: var(--pop); flex-shrink: 0; }
  a.tb-item:hover { color: var(--pop); }
  .tb-phone { font-weight: 600; color: var(--bone); }
  .tb-sep { color: rgba(242, 238, 227, 0.28); font-weight: 400; }
  .tb-social {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .tb-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: rgba(242, 238, 227, 0.7);
    transition: color 0.15s ease, transform 0.15s ease;
    border-radius: 0;
  }
  .tb-social a:hover {
    color: var(--pop);
    transform: translateY(-1px);
  }
  .tb-yelp-img {
    width: 14px;
    height: 14px;
    filter: brightness(0) invert(1) opacity(0.7);
    transition: filter 0.15s ease;
  }
  .tb-social a:hover .tb-yelp-img {
    /* on hover, tint to pop green */
    filter: brightness(0) saturate(100%) invert(56%) sepia(69%) saturate(511%) hue-rotate(86deg) brightness(95%) contrast(88%);
  }

  @media (max-width: 920px) {
    .tb-hours { display: none; }
    .tb-hide-md { display: none; }
  }
  @media (max-width: 640px) {
    .tb-inner { padding-top: 8px; padding-bottom: 8px; gap: 10px; }
    .tb-info { gap: 0; font-size: 0.66rem; letter-spacing: 0.1em; justify-content: center; flex: 1; }
    .tb-info > *:not(.tb-phone) { display: none; }
    .tb-phone { display: inline-flex; }
    .tb-social { gap: 10px; }
    .tb-social a { width: 24px; height: 24px; }
  }
</style>
