<div class="mobile-call-bar" id="mobile-call-bar">
  <a href="sms:5743862740" class="mcb-btn mcb-text">
    <span class="mcb-emoji" aria-hidden="true">💬</span>
    Text Us
  </a>
  <a href="#quote" class="mcb-btn mcb-quote" data-quote-open>
    <span class="mcb-emoji" aria-hidden="true">🌱</span>
    Free Quote
  </a>
</div>

<style>
  .mobile-call-bar {
    display: none;
    position: fixed;
    bottom: calc(16px + env(safe-area-inset-bottom));
    left: 14px;
    right: 14px;
    background: transparent;
    gap: 10px;
    z-index: 90;
    pointer-events: none;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .mobile-call-bar.is-visible {
    opacity: 1;
    transform: none;
  }
  .mcb-btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 10px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: 999px;
    text-decoration: none;
    border: 1.5px solid transparent;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    box-shadow: 0 6px 20px rgba(13, 13, 13, 0.28);
    pointer-events: auto;
  }
  .mcb-btn svg { flex-shrink: 0; }
  .mcb-emoji {
    font-size: 1.05rem;
    line-height: 1;
  }
  .mcb-btn:active { transform: translateY(1px); }

  /* Black with cream text */
  .mcb-text {
    background: var(--charcoal);
    color: var(--bone);
    border-color: var(--charcoal);
  }
  /* Cream with forest text */
  .mcb-quote {
    background: var(--bone);
    color: var(--forest);
    border-color: var(--bone);
  }

  @media (max-width: 768px) {
    .mobile-call-bar { display: flex; }
    body { padding-bottom: 88px; }
  }
</style>

<script is:inline>
  (function () {
    var bar = document.getElementById('mobile-call-bar');
    var trigger = document.getElementById('services');
    if (!bar || !trigger) return;
    if (!('IntersectionObserver' in window)) {
      bar.classList.add('is-visible');
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          bar.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0, rootMargin: '0px 0px -15% 0px' });
    io.observe(trigger);
  })();
</script>
