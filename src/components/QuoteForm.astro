---
import SectionDivider from './SectionDivider.astro';
const services = [
  'Lawn mowing & edging',
  'Bush trimming & mulch',
  'Tree branch cutting',
  'Weed, dirt & rock removal',
  'Tree or garden planting',
  'Seasonal cleanup',
  'Something else — I\'ll explain',
];
---
<section id="quote" class="section section-dark">
  <div class="container-narrow">
    <div class="quote-head text-center">
      <div class="head-top" style="justify-content: center;">
        <span class="section-num">/ 07</span>
        <span class="section-kicker">Free Estimate</span>
      </div>
      <h2 class="section-title">Request A Quote.<br/>We'll Be In Touch.</h2>
      <p class="quote-lede">Drop a few details and we'll text or call back fast — usually same day. No pressure, no hidden fees — just a fair price.</p>
    </div>

    <form class="quote-form" onsubmit="event.preventDefault(); this.querySelector('.quote-success').classList.add('show'); this.querySelector('.quote-fields').classList.add('hidden');">
      <div class="quote-fields">
        <div class="form-row">
          <label>
            <span>Your name</span>
            <input type="text" name="name" placeholder="First &amp; last" required />
          </label>
          <label>
            <span>Phone number</span>
            <input type="tel" name="phone" placeholder="(574) 123-4567" required />
          </label>
        </div>
        <div class="form-row">
          <label>
            <span>Property address or zip</span>
            <input type="text" name="address" placeholder="e.g. 46628 or full street address" required />
          </label>
          <label>
            <span>Service needed</span>
            <select name="service" required>
              <option value="">Select one…</option>
              {services.map(s => <option value={s}>{s}</option>)}
            </select>
          </label>
        </div>
        <label class="form-full">
          <span>Anything we should know? (optional)</span>
          <textarea name="notes" rows="3" placeholder="Lot size, access, special requests — or just describe what you want done."></textarea>
        </label>
        <button type="submit" class="btn btn-accent btn-lg quote-submit">
          Send Request 💚
        </button>
        <p class="quote-alt">Prefer to talk? Call or text <a href="tel:5743862740">(574) 386-2740</a> anytime.</p>
      </div>
      <div class="quote-success">
        <div class="success-icon">✓</div>
        <h3>Request received — thanks!</h3>
        <p>We'll reach out shortly to confirm details and schedule a quick look at your property. If it's urgent, call us directly at <a href="tel:5743862740">(574) 386-2740</a>.</p>
      </div>
    </form>
  </div>
  <SectionDivider variant="dark" />
</section>

<style>
  .quote-head {
    margin-bottom: 48px;
  }
  .head-top {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 18px;
  }
  .head-top .section-kicker { margin-bottom: 0; color: var(--lime); }
  .head-top .section-num { color: var(--rust); }
  .quote-lede {
    font-size: 1.1rem;
    color: rgba(242, 238, 227, 0.82);
    max-width: 560px;
    margin: 0 auto;
  }
  .quote-form {
    background: var(--bone);
    padding: 44px;
    border-radius: 0;
    border: 1.5px solid var(--bone);
    box-shadow: 10px 10px 0 var(--lime);
    position: relative;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-bottom: 18px;
  }
  label {
    display: block;
  }
  label span {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 500;
    color: var(--forest);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  input, select, textarea {
    width: 100%;
    padding: 14px 16px;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--charcoal);
    background: var(--white);
    border: 1.5px solid var(--charcoal);
    border-radius: 0;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--lime);
    box-shadow: 0 0 0 4px rgba(139, 195, 74, 0.18);
  }
  textarea {
    resize: vertical;
    min-height: 90px;
  }
  .form-full {
    margin-bottom: 24px;
  }
  .quote-submit {
    width: 100%;
    justify-content: center;
    background: var(--charcoal);
    color: var(--white);
    border-color: var(--charcoal);
    font-size: 1.08rem;
  }
  .quote-submit:hover {
    background: var(--asphalt);
    color: var(--bone);
    border-color: var(--asphalt);
  }
  .quote-alt {
    text-align: center;
    margin-top: 16px;
    font-size: 0.95rem;
    color: var(--gray);
  }
  .quote-alt a {
    color: var(--forest);
    font-weight: 600;
  }
  .quote-success {
    display: none;
    text-align: center;
    padding: 24px 0;
  }
  .quote-success.show { display: block; }
  .quote-fields.hidden { display: none; }
  .success-icon {
    width: 64px;
    height: 64px;
    background: var(--lime);
    color: var(--white);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 18px;
  }
  .quote-success h3 {
    color: var(--forest);
    margin-bottom: 10px;
  }
  .quote-success p {
    color: var(--gray);
    font-size: 1.02rem;
    max-width: 440px;
    margin: 0 auto;
  }
  .quote-success a {
    color: var(--forest);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .quote-form {
      padding: 28px 20px;
      box-shadow: 6px 6px 0 var(--pop);
    }
    .form-row { grid-template-columns: 1fr; gap: 14px; margin-bottom: 14px; }
    input, select, textarea { padding: 13px 14px; font-size: 0.98rem; }
  }
</style>
