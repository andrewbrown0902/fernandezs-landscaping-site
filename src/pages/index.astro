---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBanner from '../components/TopBanner.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Services from '../components/Services.astro';
import WhyUs from '../components/WhyUs.astro';
import Gallery from '../components/Gallery.astro';
import VideoSpotlight from '../components/VideoSpotlight.astro';
import Testimonial from '../components/Testimonial.astro';
import ServiceArea from '../components/ServiceArea.astro';
import QuoteForm from '../components/QuoteForm.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import MobileCallBar from '../components/MobileCallBar.astro';
import QuoteModal from '../components/QuoteModal.astro';
---
<BaseLayout>
  <TopBanner />
  <Header />
  <main>
    <Hero />
    <TrustStrip />
    <Services />
    <WhyUs />
    <Gallery />
    <VideoSpotlight />
    <Testimonial />
    <ServiceArea />
    <QuoteForm />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
  <MobileCallBar />
  <QuoteModal />
</BaseLayout>
